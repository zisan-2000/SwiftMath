// SEFT Abacus — Prisma schema (single source of truth for the database).
//
// Design rules baked into this schema:
//  - MULTI-INSTITUTE from day one: every domain record carries `instituteId`.
//    In Phase 1 only one institute (SEFT) is active, but the structure supports
//    many.
//  - SERVER IS THE SOURCE OF TRUTH: timing/scoring/level-up data lives here and
//    is written only by trusted server code. The practice-attempt tables that
//    record scores live with the practice engine (added in a later task); this
//    file currently defines the structural foundation (institutes, users,
//    groups, levels) plus level tracking.
//
// Prisma 7 notes: the new `prisma-client` generator emits the client into
// `lib/generated/prisma`. The datasource URL is supplied by `prisma.config.ts`
// (from DATABASE_URL), so there is no inline `url` here.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

/// A user's role.
/// STUDENT / TEACHER / ADMIN are scoped to one institute. SUPER_ADMIN is a
/// platform-level operator (Phase 2) who manages every institute; their own
/// `instituteId` points at a home institute but their access is cross-tenant.
enum Role {
  STUDENT
  TEACHER
  ADMIN
  SUPER_ADMIN
}

/// The arithmetic operation a practice level drills.
/// Phase 1 focuses on ADDITION / SUBTRACTION; the rest are reserved so we do
/// not need an enum migration to enable them later.
enum OperationType {
  ADDITION
  SUBTRACTION
  MULTIPLICATION
  DIVISION
  MIXED
}

/// Lifecycle of a timed practice attempt.
/// IN_PROGRESS → COMPLETED (submitted in time) or EXPIRED (ran out of time).
enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  EXPIRED
}

/// How a practice session is scored. STANDARD is timed and can level up;
/// REVIEW is untimed drill-only (no expiry, no level-up);
/// CHALLENGE is a harder timed drill (shorter time, higher pass bar, no level-up);
/// EXAM is a teacher-scheduled timed attempt during an exam window (can level up).
enum PracticeMode {
  STANDARD
  REVIEW
  CHALLENGE
  EXAM
}

/// Optional difficulty tag on institute question-bank entries.
enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

/// Draft questions are admin-only until published into live sessions.
enum QuestionStatus {
  DRAFT
  PUBLISHED
}

// ---------------------------------------------------------------------------
// Tenant
// ---------------------------------------------------------------------------

/// An institute is the top-level tenant. SEFT is the only active one in Phase 1.
model Institute {
  id        String   @id @default(cuid())
  /// URL-safe identifier, e.g. "seft". Unique across the platform.
  slug      String   @unique
  name      String
  /// Optional white-label branding (Phase 2.3). Shown in the authenticated UI
  /// for this tenant. Null falls back to the platform defaults.
  /// Short marketing line under the institute name.
  tagline   String?
  /// Absolute URL to the institute's logo image.
  logoUrl   String?
  /// Optional brand accent as `#RRGGBB`. Drives `--primary` in the authenticated UI.
  primaryColor String?
  /// Lets an institute be disabled without deleting its data.
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  groups           Group[]
  levels           Level[]
  practiceSessions PracticeSession[]
  scheduledExams   ScheduledExam[]
  levelQuestions   LevelQuestion[]

  @@map("institute")
}

// ---------------------------------------------------------------------------
// Auth + identity
//
// The four models below (User, Session, Account, Verification) are the shape
// better-auth's Prisma adapter expects. `User` is extended with our own fields
// (role, instituteId, group/level relations). The auth wiring itself is set up
// in a later task; here we only define the tables.
// ---------------------------------------------------------------------------

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // --- SEFT Abacus custom fields ---

  /// Drives route protection and data scoping. Carried in the session.
  role Role @default(STUDENT)

  /// Soft-disable flag. A disabled user keeps ALL their data/history but cannot
  /// sign in or use the app (enforced server-side in requireUser, which also
  /// revokes their sessions). Reversible. Mirrors Institute.isActive.
  isActive Boolean @default(true)

  /// Every user belongs to exactly one institute. Carried in the session.
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  /// Groups this user owns as a TEACHER (empty for students/admins).
  taughtGroups Group[] @relation("GroupTeacher")

  /// The group a STUDENT belongs to (null for teachers/admins, and for
  /// students not yet placed in a group).
  groupId String?
  group   Group?  @relation("GroupStudents", fields: [groupId], references: [id], onDelete: SetNull)

  /// A STUDENT's current level, used for level-up progression. Null until a
  /// teacher assigns a starting level.
  currentLevelId String?
  currentLevel   Level?  @relation("StudentCurrentLevel", fields: [currentLevelId], references: [id], onDelete: SetNull)

  /// Timed practice attempts made by this STUDENT.
  practiceSessions PracticeSession[] @relation("StudentSessions")

  /// Scheduled exams created by this teacher or admin.
  scheduledExamsCreated ScheduledExam[] @relation("ScheduledExamCreator")

  // --- better-auth relations ---
  sessions Session[]
  accounts Account[]

  @@index([instituteId])
  @@index([groupId])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  /// Hashed password for the email/password provider.
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ---------------------------------------------------------------------------
// Teaching structures
// ---------------------------------------------------------------------------

/// A teacher's class. Students are placed into a group; a group belongs to one
/// teacher and one institute.
model Group {
  id   String @id @default(cuid())
  name String

  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  /// The teacher who owns this group.
  teacherId String
  teacher   User   @relation("GroupTeacher", fields: [teacherId], references: [id], onDelete: Cascade)

  /// Students placed in this group.
  students User[] @relation("GroupStudents")

  /// Optional per-level time limits for students in this group.
  levelRules GroupLevelRule[]

  scheduledExams ScheduledExam[]

  questionRules GroupQuestionRule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instituteId])
  @@index([teacherId])
  @@map("group")
}

/// Per-group timed-practice override for a curriculum level.
/// Students in the group use this limit instead of `Level.timeLimitSeconds`.
model GroupLevelRule {
  id String @id @default(cuid())

  groupId String
  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  levelId String
  level   Level @relation(fields: [levelId], references: [id], onDelete: Cascade)

  timeLimitSeconds Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([groupId, levelId])
  @@index([groupId])
  @@index([levelId])
  @@map("group_level_rule")
}

/// A practice level: the curriculum step a student drills. Levels are ordered
/// per institute (orderIndex) and a student progresses through them.
///
/// The fields below define what the SERVER uses to generate questions and to
/// score/decide a pass — the browser never sets these.
model Level {
  id   String @id @default(cuid())
  name String

  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  /// Ordering within an institute (1, 2, 3 …). Drives level-up.
  orderIndex Int

  // --- Server-enforced scoring / timing (trusted) ---

  /// How many questions a practice session contains.
  questionCount Int
  /// Total time the server allows for the whole session, in seconds.
  timeLimitSeconds Int
  /// Minimum accuracy (percentage, 0–100) required to pass and level up.
  passAccuracy Int

  // --- Question generation parameters (Phase 1: arithmetic) ---

  /// Which operation this level drills.
  operation OperationType
  /// How many numbers appear in one question (e.g. 3 → a + b + c).
  termsPerQuestion Int
  /// Inclusive lower bound for each generated number.
  minNumber Int
  /// Inclusive upper bound for each generated number.
  maxNumber Int

  /// When true, a student must pass the previous level (by orderIndex) before
  /// practising or being assigned here. Level 1 ignores this. Admins can turn
  /// off to allow skipping ahead.
  requiresPreviousPass Boolean @default(true)

  /// When true, sessions use only fixed bank questions — no dynamic fallback.
  /// Practice and exams are blocked if the effective bank pool is too small.
  bankOnly Boolean @default(false)

  /// Students currently sitting on this level.
  studentsOnLevel User[] @relation("StudentCurrentLevel")

  /// Practice attempts made at this level.
  practiceSessions PracticeSession[]

  groupLevelRules GroupLevelRule[]

  scheduledExams ScheduledExam[]

  levelQuestions LevelQuestion[]

  /// When set, the level is archived (soft-deleted). Hidden from assignment and
  /// new practice; existing session history is kept.
  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // No two levels in the same institute share an order position.
  @@unique([instituteId, orderIndex])
  @@index([instituteId])
  @@map("level")
}

// ---------------------------------------------------------------------------
// Institute question bank
//
// LevelQuestion entries are owned by the institute Admin. Teachers can disable
// specific questions for their group via GroupQuestionRule. When the bank is
// empty or too small, the practice engine falls back to dynamic generation.
// ---------------------------------------------------------------------------

model LevelQuestion {
  id String @id @default(cuid())

  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  levelId String
  level   Level @relation(fields: [levelId], references: [id], onDelete: Cascade)

  /// Display prompt, e.g. "12 + 7 + 3".
  prompt String

  /// Trusted answer — never sent to the client during an in-progress session.
  correctAnswer Int

  /// Optional curriculum tag, e.g. "Carry", "Speed drill".
  category String?

  difficulty QuestionDifficulty @default(MEDIUM)

  /// Draft rows are hidden from practice/exams until published.
  status QuestionStatus @default(DRAFT)

  /// Institute-wide active flag (Admin). Inactive questions are never picked.
  isActive Boolean @default(true)

  /// Sort hint for Admin lists; does not affect random session pick order.
  orderIndex Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groupRules         GroupQuestionRule[]
  practiceQuestions  PracticeQuestion[]
  scheduledExamQuestions ScheduledExamQuestion[]

  @@index([instituteId])
  @@index([levelId])
  @@index([levelId, isActive])
  @@index([levelId, status])
  @@map("level_question")
}

/// Per-group enable/disable override for a bank question (Teacher).
/// No row means enabled (when the parent LevelQuestion is active).
model GroupQuestionRule {
  id String @id @default(cuid())

  groupId String
  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  questionId String
  question   LevelQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  enabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([groupId, questionId])
  @@index([groupId])
  @@index([questionId])
  @@map("group_question_rule")
}

// ---------------------------------------------------------------------------
// Scheduled exams
//
// A teacher schedules a timed exam window for a group at a specific level.
// Students in that group may start one attempt while the window is open.
// ---------------------------------------------------------------------------

model ScheduledExam {
  id String @id @default(cuid())

  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  groupId String
  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  levelId String
  level   Level @relation(fields: [levelId], references: [id])

  /// Optional label shown on the student dashboard (e.g. "Weekly test").
  title String?

  /// Inclusive window when students may start the exam (server clock).
  opensAt  DateTime
  closesAt DateTime

  createdById String
  createdBy   User @relation("ScheduledExamCreator", fields: [createdById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  practiceSessions PracticeSession[]
  paperQuestions   ScheduledExamQuestion[]

  @@index([instituteId])
  @@index([groupId])
  @@index([opensAt, closesAt])
  @@map("scheduled_exam")
}

/// Fixed question paper for a scheduled exam — identical for every student in the group.
model ScheduledExamQuestion {
  id String @id @default(cuid())

  scheduledExamId String
  scheduledExam   ScheduledExam @relation(fields: [scheduledExamId], references: [id], onDelete: Cascade)

  /// Position within the paper (0-based).
  index Int

  prompt        String
  correctAnswer Int

  /// When picked from the institute bank, links back for analytics/audit.
  sourceQuestionId String?
  sourceQuestion   LevelQuestion? @relation(fields: [sourceQuestionId], references: [id], onDelete: SetNull)

  @@unique([scheduledExamId, index])
  @@index([scheduledExamId])
  @@map("scheduled_exam_question")
}

// ---------------------------------------------------------------------------
// Practice attempts
//
// A PracticeSession is one timed attempt by a student at a level. EVERYTHING
// that matters for fairness lives here and is written only by trusted server
// code: the server generates the questions (storing the correct answers, which
// are never sent to the browser until grading), stamps startedAt/expiresAt, and
// computes correctness, accuracy, pass, and level-up on submit.
// ---------------------------------------------------------------------------

model PracticeSession {
  id String @id @default(cuid())

  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  studentId String
  student   User   @relation("StudentSessions", fields: [studentId], references: [id], onDelete: Cascade)

  levelId String
  level   Level   @relation(fields: [levelId], references: [id])

  status SessionStatus @default(IN_PROGRESS)

  /// STANDARD = timed attempt that can level up; REVIEW = untimed drill;
  /// CHALLENGE = harder timed drill without level-up;
  /// EXAM = scheduled timed attempt linked to a ScheduledExam.
  mode PracticeMode @default(STANDARD)

  /// Set when `mode` is EXAM — links this attempt to the scheduled exam slot.
  scheduledExamId String?
  scheduledExam   ScheduledExam? @relation(fields: [scheduledExamId], references: [id], onDelete: SetNull)

  /// Server clock. The session must be submitted on or before `expiresAt`.
  startedAt   DateTime  @default(now())
  expiresAt   DateTime
  submittedAt DateTime?

  // --- Server-computed results (trusted) ---
  totalQuestions Int
  correctCount   Int     @default(0)
  /// Accuracy as a percentage, 0–100.
  accuracy       Int     @default(0)
  /// Did the attempt meet the level's pass threshold (in time)?
  passed         Boolean @default(false)
  /// Did passing this attempt advance the student to the next level?
  leveledUp      Boolean @default(false)

  /// Server-detected anomaly flags (informational; no auto-penalty yet).
  anomalyFlags String[] @default([])

  createdAt DateTime @default(now())

  questions PracticeQuestion[]

  @@unique([studentId, scheduledExamId])
  @@index([studentId])
  @@index([instituteId])
  @@index([levelId])
  @@index([scheduledExamId])
  @@map("practice_session")
}

model PracticeQuestion {
  id String @id @default(cuid())

  sessionId String
  session   PracticeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  /// Position within the session (0-based).
  index Int

  /// Human-readable prompt shown to the student, e.g. "12 + 7 + 3".
  prompt String

  /// The correct answer — server-only. Never serialised to the client while a
  /// session is in progress.
  correctAnswer Int

  /// What the student submitted (null if left blank / not reached).
  studentAnswer Int?
  /// Graded server-side on submit.
  isCorrect Boolean?

  /// When picked from the institute bank, links back for analytics/audit.
  sourceQuestionId String?
  sourceQuestion   LevelQuestion? @relation(fields: [sourceQuestionId], references: [id], onDelete: SetNull)

  @@unique([sessionId, index])
  @@index([sessionId])
  @@index([sourceQuestionId])
  @@map("practice_question")
}
