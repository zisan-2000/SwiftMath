# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but always commit the template so new clones know which vars to set.
!.env.example

# vercel
.vercel

# locally uploaded institute logos (dev fallback when Blob is not configured)
/public/uploads/*
!/public/uploads/.gitkeep

# typescript
*.tsbuildinfo
next-env.d.ts

# Serwist (legacy manual SW path; Turbopack serves /serwist/sw.js)
public/sw.js
public/sw.js.map

/lib/generated/prisma
