# ---------------------------------------------------------------------------
# SEFT Abacus — environment variables
#
# Copy this file to `.env` and fill in real values. `.env` is git-ignored;
# this template is committed so every clone knows which variables are required.
#
# Full deployment steps: docs/DEPLOYMENT.md
# ---------------------------------------------------------------------------

# --- Database (required) ---------------------------------------------------
# PostgreSQL connection string used by Prisma and the app at runtime.
#
# Local:
#   postgresql://USER:PASSWORD@localhost:5432/seft_abacus?schema=public
# Neon / Railway (managed — usually needs SSL):
#   postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/seft_abacus?schema=public"

# --- better-auth (required) ------------------------------------------------
# Secret used to sign session cookies. Use a strong random value per environment.
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET="pegmsyXYGDa2g6LiApHRha9+7HexKr2U6pwgZJauotA="

# Public origin of the app — no trailing slash. Must match the URL in the browser.
# Local:  http://localhost:3000
# Prod:  https://app.yourdomain.com
BETTER_AUTH_URL="http://localhost:3000"

# --- Email / password reset (Phase 2.4) ------------------------------------
# Optional locally — without RESEND_API_KEY the reset link is printed in the
# dev-server terminal instead of being emailed.
#
# Resend: https://resend.com — create an API key and verify your sending domain.
# Free tier test: use onboarding@resend.dev as FROM (only delivers to your
# Resend account email until a domain is verified).
RESEND_API_KEY=""
EMAIL_FROM="SEFT Abacus <onboarding@resend.dev>"

# --- Logo uploads (Phase 3.2) ----------------------------------------------
# Optional locally — without BLOB_READ_WRITE_TOKEN logos save under
# public/uploads/ during development. Required on Vercel/production.
#
# Vercel Blob: Project → Storage → Blob → create store → copy token.
BLOB_READ_WRITE_TOKEN=""
