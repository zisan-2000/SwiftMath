# ---------------------------------------------------------------------------
# SEFT Abacus — environment variables
#
# Copy this file to `.env` and fill in real values. `.env` is git-ignored;
# this template is committed so every clone knows which variables are required.
# ---------------------------------------------------------------------------

# PostgreSQL connection string used by Prisma.
# Local example: postgresql://USER:PASSWORD@localhost:5432/seft_abacus?schema=public
# Neon/Railway will give you a full URL (often needs ?sslmode=require).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/seft_abacus?schema=public"

# better-auth — secret used to sign sessions. Generate a strong random value:
#   openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-in-production"

# Base URL of the app, used by better-auth for callbacks/cookies.
# In local dev this is the dev server URL.
BETTER_AUTH_URL="http://localhost:3000"
